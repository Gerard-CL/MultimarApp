<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_pedido_id"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="ID del Pedido: 080205340"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/tv_pedido_status"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tv_pedido_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status_pill" android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="Preparación"
            android:textColor="@color/status_prep_text"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            app:backgroundTint="@color/status_prep_bg"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/iv_client_icon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginTop="12dp"
            android:src="@drawable/ic_user" app:tint="@color/black"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_pedido_id" />

        <TextView
            android:id="@+id/tv_cliente_nombre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Cliente: Juan"
            android:textColor="@color/black"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="@id/iv_client_icon"
            app:layout_constraintStart_toEndOf="@id/iv_client_icon"
            app:layout_constraintTop_toTopOf="@id/iv_client_icon" />

        <ImageView
            android:id="@+id/iv_origin_icon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginTop="12dp"
            android:src="@drawable/ic_location" app:tint="@color/black"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/iv_client_icon" />

        <TextView
            android:id="@+id/tv_origen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Shanghai"
            android:textColor="@color/black"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="@id/iv_origin_icon"
            app:layout_constraintStart_toEndOf="@id/iv_origin_icon"
            app:layout_constraintTop_toTopOf="@id/iv_origin_icon" />

        <ImageView
            android:id="@+id/iv_arrow_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="12dp"
            android:src="@drawable/ic_arrow_right" app:tint="@color/black"
            app:layout_constraintBottom_toBottomOf="@id/tv_origen"
            app:layout_constraintStart_toEndOf="@id/tv_origen"
            app:layout_constraintTop_toTopOf="@id/tv_origen" />

        <ImageView
            android:id="@+id/iv_dest_icon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="12dp"
            android:src="@drawable/ic_location" app:tint="@color/black"
            app:layout_constraintBottom_toBottomOf="@id/iv_arrow_icon"
            app:layout_constraintStart_toEndOf="@id/iv_arrow_icon"
            app:layout_constraintTop_toTopOf="@id/iv_arrow_icon" />

        <TextView
            android:id="@+id/tv_destino"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Barcelona"
            android:textColor="@color/black"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="@id/iv_dest_icon"
            app:layout_constraintStart_toEndOf="@id/iv_dest_icon"
            app:layout_constraintTop_toTopOf="@id/iv_dest_icon" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>