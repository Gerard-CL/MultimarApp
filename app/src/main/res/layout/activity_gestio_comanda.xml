<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF5F9"> <View
    android:id="@+id/topBackground"
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:background="#06192E"
    app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="56dp"
        android:src="@drawable/ic_back_arrow"
        app:tint="#FFFFFF"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/llTitles"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="@+id/btnBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/btnBack"
        app:layout_constraintTop_toTopOf="@+id/btnBack">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gestión de comanda:"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="#1354631685"
            android:textColor="#8DBDF1"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@+id/llTitles">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Electrodomesticos S.A"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_location_pin"
                    app:tint="#000000" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Shanghai"
                    android:textColor="#000000"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:text="→"
                    android:textColor="#000000"
                    android:textSize="20sp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_location_pin"
                    app:tint="#000000" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Barcelona"
                    android:textColor="#000000"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/bottomContainer"
        app:layout_constraintTop_toBottomOf="@+id/cardInfo">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="24dp">

            <View
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:background="#52C468"
                app:layout_constraintBottom_toBottomOf="@+id/node1"
                app:layout_constraintEnd_toStartOf="@+id/node2"
                app:layout_constraintStart_toEndOf="@+id/node1"
                app:layout_constraintTop_toTopOf="@+id/node1" />

            <View
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:background="#52C468"
                app:layout_constraintBottom_toBottomOf="@+id/node2"
                app:layout_constraintEnd_toStartOf="@+id/node3"
                app:layout_constraintStart_toEndOf="@+id/node2"
                app:layout_constraintTop_toTopOf="@+id/node2" />

            <View
                android:layout_width="4dp"
                android:layout_height="0dp"
                android:background="#52C468"
                app:layout_constraintBottom_toTopOf="@+id/node4"
                app:layout_constraintEnd_toEndOf="@+id/node3"
                app:layout_constraintStart_toStartOf="@+id/node3"
                app:layout_constraintTop_toBottomOf="@+id/node3" />

            <View
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:background="#52C468"
                app:layout_constraintBottom_toBottomOf="@+id/node4"
                app:layout_constraintEnd_toStartOf="@+id/node4"
                app:layout_constraintStart_toEndOf="@+id/node5"
                app:layout_constraintTop_toTopOf="@+id/node4" />

            <View
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:background="#8DBDF1"
                app:layout_constraintBottom_toBottomOf="@+id/node5"
                app:layout_constraintEnd_toStartOf="@+id/node5"
                app:layout_constraintStart_toEndOf="@+id/node6"
                app:layout_constraintTop_toTopOf="@+id/node5" />

            <View
                android:layout_width="4dp"
                android:layout_height="0dp"
                android:background="#E0E0E0"
                app:layout_constraintBottom_toTopOf="@+id/node7"
                app:layout_constraintEnd_toEndOf="@+id/node6"
                app:layout_constraintStart_toStartOf="@+id/node6"
                app:layout_constraintTop_toBottomOf="@+id/node6" />

            <View
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:background="#E0E0E0"
                app:layout_constraintBottom_toBottomOf="@+id/node7"
                app:layout_constraintEnd_toStartOf="@+id/node8"
                app:layout_constraintStart_toEndOf="@+id/node7"
                app:layout_constraintTop_toTopOf="@+id/node7" />

            <View
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:background="#E0E0E0"
                app:layout_constraintBottom_toBottomOf="@+id/node8"
                app:layout_constraintEnd_toStartOf="@+id/node9"
                app:layout_constraintStart_toEndOf="@+id/node8"
                app:layout_constraintTop_toTopOf="@+id/node8" />

            <ImageView
                android:id="@+id/node1"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_check_green"
                app:layout_constraintEnd_toStartOf="@+id/node2"
                app:layout_constraintHorizontal_chainStyle="spread_inside"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Preparación"
                android:textColor="#000000"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@+id/node1"
                app:layout_constraintEnd_toEndOf="@+id/node1"
                app:layout_constraintStart_toStartOf="@+id/node1" />

            <ImageView
                android:id="@+id/node2"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_check_green"
                app:layout_constraintEnd_toStartOf="@+id/node3"
                app:layout_constraintStart_toEndOf="@+id/node1"
                app:layout_constraintTop_toTopOf="@+id/node1" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="Transporte\ninterior origen"
                android:textColor="#000000"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@+id/node2"
                app:layout_constraintEnd_toEndOf="@+id/node2"
                app:layout_constraintStart_toStartOf="@+id/node2" />

            <ImageView
                android:id="@+id/node3"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_check_green"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/node2"
                app:layout_constraintTop_toTopOf="@+id/node1" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="Terminal/\nPuerto origen"
                android:textColor="#000000"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@+id/node3"
                app:layout_constraintEnd_toEndOf="@+id/node3"
                app:layout_constraintStart_toStartOf="@+id/node3" />

            <ImageView
                android:id="@+id/node6"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="64dp"
                android:src="@drawable/ic_check_blue"
                app:layout_constraintEnd_toEndOf="@+id/node1"
                app:layout_constraintStart_toStartOf="@+id/node1"
                app:layout_constraintTop_toBottomOf="@+id/node1" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="Puerto\ndestino"
                android:textColor="#000000"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@+id/node6"
                app:layout_constraintEnd_toEndOf="@+id/node6"
                app:layout_constraintStart_toStartOf="@+id/node6" />

            <ImageView
                android:id="@+id/node5"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_check_green"
                app:layout_constraintEnd_toEndOf="@+id/node2"
                app:layout_constraintStart_toStartOf="@+id/node2"
                app:layout_constraintTop_toTopOf="@+id/node6" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Transporte"
                android:textColor="#000000"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@+id/node5"
                app:layout_constraintStart_toStartOf="@+id/node5"
                app:layout_constraintTop_toBottomOf="@+id/node5" />

            <ImageView
                android:id="@+id/node4"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_check_green"
                app:layout_constraintEnd_toEndOf="@+id/node3"
                app:layout_constraintStart_toStartOf="@+id/node3"
                app:layout_constraintTop_toTopOf="@+id/node6" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Carga a\nbordo"
                android:textColor="#000000"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@+id/node4"
                app:layout_constraintStart_toStartOf="@+id/node4"
                app:layout_constraintTop_toBottomOf="@+id/node4" />

            <ImageView
                android:id="@+id/node7"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="64dp"
                app:layout_constraintEnd_toEndOf="@+id/node6"
                app:layout_constraintStart_toStartOf="@+id/node6"
                app:layout_constraintTop_toBottomOf="@+id/node6" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Duana\nimportación"
                android:textColor="#000000"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@+id/node7"
                app:layout_constraintStart_toStartOf="@+id/node7"
                app:layout_constraintTop_toBottomOf="@+id/node7" />

            <ImageView
                android:id="@+id/node8"
                android:layout_width="32dp"
                android:layout_height="32dp"
                app:layout_constraintEnd_toEndOf="@+id/node5"
                app:layout_constraintStart_toStartOf="@+id/node5"
                app:layout_constraintTop_toTopOf="@+id/node7" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Transporte\ninterior destino"
                android:textColor="#000000"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@+id/node8"
                app:layout_constraintStart_toStartOf="@+id/node8"
                app:layout_constraintTop_toBottomOf="@+id/node8" />

            <ImageView
                android:id="@+id/node9"
                android:layout_width="32dp"
                android:layout_height="32dp"
                app:layout_constraintEnd_toEndOf="@+id/node4"
                app:layout_constraintStart_toStartOf="@+id/node4"
                app:layout_constraintTop_toTopOf="@+id/node7" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Entrega final"
                android:textColor="#000000"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@+id/node9"
                app:layout_constraintStart_toStartOf="@+id/node9"
                app:layout_constraintTop_toBottomOf="@+id/node9" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavLayout">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnSiguiente"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            app:cardBackgroundColor="#8DBDF1"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:id="@+id/icNextArrow"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_circle_white"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#8DBDF1"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Siguiente Paso"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <include layout="@layout/layout_bottom_nav"
        android:id="@+id/bottomNavLayout"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>