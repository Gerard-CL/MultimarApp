<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    tools:context=".TrackingActivity">

    <View
        android:id="@+id/header_bg_view"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@drawable/header_background"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_back"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="40dp"
        android:src="@drawable/ic_arrow_back" app:tint="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gestión de comanda:\n#1354631685"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toEndOf="@id/iv_back"
        app:layout_constraintTop_toTopOf="@id/iv_back"
        app:layout_constraintBottom_toBottomOf="@id/iv_back"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView
                android:id="@+id/tv_empresa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Electrodomesticos S.A"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="16sp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">
                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_location" app:tint="@color/black"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Shanghai" android:textColor="@color/black" android:layout_marginStart="4dp"/>
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_arrow_right" app:tint="@color/black" android:layout_marginHorizontal="8dp"/>
                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_location" app:tint="@color/black"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Barcelona" android:textColor="@color/black" android:layout_marginStart="4dp"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.constraintlayout.widget.Guideline android:id="@+id/gl_left" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" app:layout_constraintGuide_percent="0.15"/>
    <androidx.constraintlayout.widget.Guideline android:id="@+id/gl_center" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" app:layout_constraintGuide_percent="0.5"/>
    <androidx.constraintlayout.widget.Guideline android:id="@+id/gl_right" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" app:layout_constraintGuide_percent="0.85"/>

    <View android:id="@+id/line_1_2" android:layout_width="0dp" android:layout_height="4dp" android:background="@color/track_green" app:layout_constraintStart_toStartOf="@id/gl_left" app:layout_constraintEnd_toEndOf="@id/gl_center" app:layout_constraintTop_toTopOf="@id/iv_step_1" app:layout_constraintBottom_toBottomOf="@id/iv_step_1"/>
    <View android:id="@+id/line_2_3" android:layout_width="0dp" android:layout_height="4dp" android:background="@color/track_green" app:layout_constraintStart_toStartOf="@id/gl_center" app:layout_constraintEnd_toEndOf="@id/gl_right" app:layout_constraintTop_toTopOf="@id/iv_step_2" app:layout_constraintBottom_toBottomOf="@id/iv_step_2"/>

    <View android:id="@+id/line_3_4" android:layout_width="4dp" android:layout_height="0dp" android:background="@color/track_green" app:layout_constraintTop_toTopOf="@id/iv_step_3" app:layout_constraintBottom_toBottomOf="@id/iv_step_4" app:layout_constraintStart_toStartOf="@id/iv_step_3" app:layout_constraintEnd_toEndOf="@id/iv_step_3"/>

    <View android:id="@+id/line_4_5" android:layout_width="0dp" android:layout_height="4dp" android:background="@color/track_green" app:layout_constraintStart_toStartOf="@id/gl_center" app:layout_constraintEnd_toEndOf="@id/gl_right" app:layout_constraintTop_toTopOf="@id/iv_step_4" app:layout_constraintBottom_toBottomOf="@id/iv_step_4"/>
    <View android:id="@+id/line_5_6" android:layout_width="0dp" android:layout_height="4dp" android:background="@color/track_blue" app:layout_constraintStart_toStartOf="@id/gl_left" app:layout_constraintEnd_toEndOf="@id/gl_center" app:layout_constraintTop_toTopOf="@id/iv_step_5" app:layout_constraintBottom_toBottomOf="@id/iv_step_5"/>

    <View android:id="@+id/line_6_7" android:layout_width="4dp" android:layout_height="0dp" android:background="@color/track_grey" app:layout_constraintTop_toTopOf="@id/iv_step_6" app:layout_constraintBottom_toBottomOf="@id/iv_step_7" app:layout_constraintStart_toStartOf="@id/iv_step_6" app:layout_constraintEnd_toEndOf="@id/iv_step_6"/>

    <View android:id="@+id/line_7_8" android:layout_width="0dp" android:layout_height="4dp" android:background="@color/track_grey" app:layout_constraintStart_toStartOf="@id/gl_left" app:layout_constraintEnd_toEndOf="@id/gl_center" app:layout_constraintTop_toTopOf="@id/iv_step_7" app:layout_constraintBottom_toBottomOf="@id/iv_step_7"/>
    <View android:id="@+id/line_8_9" android:layout_width="0dp" android:layout_height="4dp" android:background="@color/track_grey" app:layout_constraintStart_toStartOf="@id/gl_center" app:layout_constraintEnd_toEndOf="@id/gl_right" app:layout_constraintTop_toTopOf="@id/iv_step_8" app:layout_constraintBottom_toBottomOf="@id/iv_step_8"/>

    <ImageView android:id="@+id/iv_step_1" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginTop="50dp" android:src="@drawable/ic_check_green_circle" app:layout_constraintTop_toBottomOf="@id/card_info" app:layout_constraintStart_toStartOf="@id/gl_left" app:layout_constraintEnd_toEndOf="@id/gl_left"/>
    <ImageView android:id="@+id/iv_step_2" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_check_green_circle" app:layout_constraintTop_toTopOf="@id/iv_step_1" app:layout_constraintStart_toStartOf="@id/gl_center" app:layout_constraintEnd_toEndOf="@id/gl_center"/>
    <ImageView android:id="@+id/iv_step_3" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_check_green_circle" app:layout_constraintTop_toTopOf="@id/iv_step_1" app:layout_constraintStart_toStartOf="@id/gl_right" app:layout_constraintEnd_toEndOf="@id/gl_right"/>

    <ImageView android:id="@+id/iv_step_4" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginTop="60dp" android:src="@drawable/ic_check_green_circle" app:layout_constraintTop_toBottomOf="@id/iv_step_3" app:layout_constraintStart_toStartOf="@id/gl_right" app:layout_constraintEnd_toEndOf="@id/gl_right"/>
    <ImageView android:id="@+id/iv_step_5" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_check_green_circle" app:layout_constraintTop_toTopOf="@id/iv_step_4" app:layout_constraintStart_toStartOf="@id/gl_center" app:layout_constraintEnd_toEndOf="@id/gl_center"/>
    <ImageView android:id="@+id/iv_step_6" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_check_blue_circle" app:layout_constraintTop_toTopOf="@id/iv_step_4" app:layout_constraintStart_toStartOf="@id/gl_left" app:layout_constraintEnd_toEndOf="@id/gl_left"/>

    <ImageView android:id="@+id/iv_step_7" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginTop="60dp" android:src="@drawable/ic_circle_grey_outline" app:layout_constraintTop_toBottomOf="@id/iv_step_6" app:layout_constraintStart_toStartOf="@id/gl_left" app:layout_constraintEnd_toEndOf="@id/gl_left"/>
    <ImageView android:id="@+id/iv_step_8" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_circle_grey_outline" app:layout_constraintTop_toTopOf="@id/iv_step_7" app:layout_constraintStart_toStartOf="@id/gl_center" app:layout_constraintEnd_toEndOf="@id/gl_center"/>
    <ImageView android:id="@+id/iv_step_9" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_circle_grey_outline" app:layout_constraintTop_toTopOf="@id/iv_step_7" app:layout_constraintStart_toStartOf="@id/gl_right" app:layout_constraintEnd_toEndOf="@id/gl_right"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Preparación" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/header_bg" app:layout_constraintBottom_toTopOf="@id/iv_step_1" app:layout_constraintStart_toStartOf="@id/iv_step_1" app:layout_constraintEnd_toEndOf="@id/iv_step_1" android:layout_marginBottom="8dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Transporte\ninterior origen" android:textAlignment="center" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/header_bg" app:layout_constraintBottom_toTopOf="@id/iv_step_2" app:layout_constraintStart_toStartOf="@id/iv_step_2" app:layout_constraintEnd_toEndOf="@id/iv_step_2" android:layout_marginBottom="8dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Terminal/\nPuerto origen" android:textAlignment="center" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/header_bg" app:layout_constraintBottom_toTopOf="@id/iv_step_3" app:layout_constraintStart_toStartOf="@id/iv_step_3" app:layout_constraintEnd_toEndOf="@id/iv_step_3" android:layout_marginBottom="8dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Carga a\nbordo" android:textAlignment="center" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/header_bg" app:layout_constraintTop_toBottomOf="@id/iv_step_4" app:layout_constraintStart_toStartOf="@id/iv_step_4" app:layout_constraintEnd_toEndOf="@id/iv_step_4" android:layout_marginTop="8dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Transporte" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/header_bg" app:layout_constraintTop_toBottomOf="@id/iv_step_5" app:layout_constraintStart_toStartOf="@id/iv_step_5" app:layout_constraintEnd_toEndOf="@id/iv_step_5" android:layout_marginTop="8dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Puerto\ndestino" android:textAlignment="center" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/header_bg" app:layout_constraintBottom_toTopOf="@id/iv_step_6" app:layout_constraintStart_toStartOf="@id/iv_step_6" app:layout_constraintEnd_toEndOf="@id/iv_step_6" android:layout_marginBottom="8dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Duana\nimportación" android:textAlignment="center" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/header_bg" app:layout_constraintTop_toBottomOf="@id/iv_step_7" app:layout_constraintStart_toStartOf="@id/iv_step_7" app:layout_constraintEnd_toEndOf="@id/iv_step_7" android:layout_marginTop="8dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Transporte\ninterior destino" android:textAlignment="center" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/header_bg" app:layout_constraintTop_toBottomOf="@id/iv_step_8" app:layout_constraintStart_toStartOf="@id/iv_step_8" app:layout_constraintEnd_toEndOf="@id/iv_step_8" android:layout_marginTop="8dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Entrega final" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/header_bg" app:layout_constraintTop_toBottomOf="@id/iv_step_9" app:layout_constraintStart_toStartOf="@id/iv_step_9" app:layout_constraintEnd_toEndOf="@id/iv_step_9" android:layout_marginTop="8dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_bottom_sheet_rounded" app:layout_constraintTop_toTopOf="@id/btn_siguiente_paso"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginTop="-24dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_siguiente_paso"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="24dp"
        android:text="Siguiente Paso"
        android:textColor="@color/white"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="@color/btn_blue"
        app:cornerRadius="20dp" app:icon="@drawable/ic_arrow_circle_white"
        app:iconTint="@null" app:iconSize="40dp"
        app:iconGravity="start" app:iconPadding="0dp"

        app:layout_constraintBottom_toTopOf="@id/bottom_navigation" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>